<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_50">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_circle_decoration"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="-40dp"
            android:layout_marginTop="-40dp" />

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_queue_chip"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:contentDescription="Back" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book a Queue"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_below="@id/btn_back" />

        <TextView
            android:id="@+id/tv_header_service"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your preferred date and time"
            android:textColor="#BFFFFFFF"
            android:textSize="13sp"
            android:layout_below="@id/tv_header_title"
            android:layout_marginTop="4dp" />

    </RelativeLayout>

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical">

        <!-- Step 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <LinearLayout
                android:id="@+id/step1_circle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_active"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/step1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="@color/blue_600"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/gray_200"
            android:layout_marginHorizontal="8dp" />

        <!-- Step 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <LinearLayout
                android:id="@+id/step2_circle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="@color/gray_400"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/step2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time Slot"
                android:textColor="@color/gray_400"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/gray_200"
            android:layout_marginHorizontal="8dp" />

        <!-- Step 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <LinearLayout
                android:id="@+id/step3_circle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="@color/gray_400"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/step3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm"
                android:textColor="@color/gray_400"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Content area — changes per step -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- STEP 1: Date Picker -->
            <LinearLayout
                android:id="@+id/layout_step1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select a date"
                    android:textColor="@color/gray_800"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    style="@style/Widget.BarangayGo.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <CalendarView
                        android:id="@+id/calendar_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:dateTextAppearance="@android:style/TextAppearance.Small" />
                </androidx.cardview.widget.CardView>

                <!-- Slot availability preview for selected date -->
                <LinearLayout
                    android:id="@+id/layout_date_availability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_announce_info"
                    android:visibility="gone">
                    <ProgressBar
                        android:id="@+id/availability_loading"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone" />
                    <ImageView
                        android:id="@+id/availability_icon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_bell_blue"
                        android:visibility="gone"
                        android:contentDescription="Availability" />
                    <TextView
                        android:id="@+id/tv_date_availability"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_announce_info"
                    android:padding="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_bell_blue"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Info" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Queue slots are available Monday to Saturday only"
                        android:textColor="@color/blue_600"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 2: Time Slot Selection -->
            <LinearLayout
                android:id="@+id/layout_step2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_selected_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available slots for June 3, 2025"
                    android:textColor="@color/gray_800"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/slots_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <!-- No slots message -->
                <LinearLayout
                    android:id="@+id/layout_no_slots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_announce_warning"
                    android:padding="16dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No available slots"
                        android:textColor="#7C2D12"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please select a different date"
                        android:textColor="#C2410C"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Slots container -->
                <LinearLayout
                    android:id="@+id/slots_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- STEP 3: Confirmation -->
            <LinearLayout
                android:id="@+id/layout_step3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm your booking"
                    android:textColor="@color/gray_800"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Booking summary card -->
                <androidx.cardview.widget.CardView
                    style="@style/Widget.BarangayGo.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">
                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_announce_icon_info"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_services"
                                    app:tint="@color/blue_600"
                                    android:contentDescription="Service" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Booking Summary"
                                    android:textColor="@color/gray_400"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tv_confirm_service"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Barangay Clearance"
                                    android:textColor="@color/gray_800"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/gray_100"
                            android:layout_marginBottom="14dp" />

                        <!-- Date row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Date"
                                android:textColor="@color/gray_400"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tv_confirm_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="June 3, 2025"
                                android:textColor="@color/gray_800"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Time row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Time Slot"
                                android:textColor="@color/gray_400"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tv_confirm_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="9:00 AM – 9:30 AM"
                                android:textColor="@color/gray_800"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Slots remaining row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Slots Remaining"
                                android:textColor="@color/gray_400"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tv_confirm_slots"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12 of 30"
                                android:textColor="@color/status_success"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Reminder card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_announce_info"
                    android:padding="14dp"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_bell_blue"
                        android:layout_marginEnd="10dp"
                        android:layout_marginTop="2dp"
                        android:contentDescription="Info" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please arrive at least 10 minutes before your time slot. Bring all required documents."
                        android:textColor="@color/blue_600"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_step"
            style="@style/Widget.BarangayGo.Button.Outline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_step"
            style="@style/Widget.BarangayGo.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Next" />

    </LinearLayout>

</LinearLayout>