<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.BarangayGo.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Queue number badge -->
        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_announce_icon_info"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="14dp">
            <TextView
                android:id="@+id/tv_queue_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A-001"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600"
                android:gravity="center" />
        </LinearLayout>

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_service_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/gray_800"
                android:fontFamily="@font/nunito_extrabold" />

            <TextView
                android:id="@+id/tv_date_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="May 21 · 8:00 AM – 10:00 AM"
                android:textSize="12sp"
                android:textColor="@color/gray_400"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_ahead_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 ahead · ~15 min"
                android:textSize="11sp"
                android:textColor="@color/gray_400"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WAITING"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>