<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_50">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_circle_decoration"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="-40dp"
            android:layout_marginTop="-40dp" />

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_queue_chip"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:contentDescription="Back" />
        </LinearLayout>

        <!-- Service icon -->
        <LinearLayout
            android:id="@+id/service_icon_bg"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_logo_container"
            android:gravity="center"
            android:layout_below="@id/btn_back"
            android:layout_marginBottom="14dp">
            <ImageView
                android:id="@+id/iv_service_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_services"
                android:contentDescription="Service Icon" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_service_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service Name"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_below="@id/service_icon_bg" />

        <TextView
            android:id="@+id/tv_service_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Service description"
            android:textColor="#BFFFFFFF"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_below="@id/tv_service_name"
            android:layout_marginTop="6dp" />

    </RelativeLayout>

    <!-- Info chips row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Est. time chip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_announce_icon_info"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Est. Time"
                android:textColor="@color/blue_600"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/tv_est_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 mins"
                android:textColor="@color/blue_800"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Availability chip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_announce_icon_success"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginStart="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textColor="@color/status_success"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/tv_availability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textColor="@color/status_success"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Requirements card -->
            <androidx.cardview.widget.CardView
                style="@style/Widget.BarangayGo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requirements"
                        android:textColor="@color/gray_800"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/requirements_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Steps card -->
            <androidx.cardview.widget.CardView
                style="@style/Widget.BarangayGo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How it works"
                        android:textColor="@color/gray_800"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Step 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_circle"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="@color/blue_600"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Book a queue slot"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Step 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_circle"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="@color/blue_600"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prepare your requirements"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Step 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_circle"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="@color/blue_600"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Go to the barangay office at your scheduled time"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Step 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_circle"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:textColor="@color/blue_600"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Receive your document"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Office hours card -->
            <androidx.cardview.widget.CardView
                style="@style/Widget.BarangayGo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Office Hours"
                        android:textColor="@color/gray_800"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Monday – Friday"
                            android:textColor="@color/gray_600"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8:00 AM – 5:00 PM"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Saturday"
                            android:textColor="@color/gray_600"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8:00 AM – 12:00 PM"
                            android:textColor="@color/gray_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Book Now Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_book_now"
            style="@style/Widget.BarangayGo.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book a Queue Slot" />

    </LinearLayout>

</LinearLayout>