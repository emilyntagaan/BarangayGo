<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_barangay_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/gray_200"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Barangay logo bubble (logo image with initial fallback) -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">

            <!-- Fallback initial bubble shown when no logo -->
            <LinearLayout
                android:id="@+id/layout_logo_fallback"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_step_active"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_logo_initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Actual logo image (rounded) -->
            <ImageView
                android:id="@+id/iv_barangay_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_step_active"
                android:visibility="gone"
                android:contentDescription="Barangay logo" />

        </FrameLayout>

        <!-- Name + location -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_barangay_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barangay Name"
                android:textColor="@color/gray_800"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_barangay_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Municipality, Province"
                android:textColor="@color/gray_400"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_barangay_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_waiting"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="BGY-001"
                android:textColor="@color/blue_600"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Check icon -->
        <ImageView
            android:id="@+id/iv_check"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_check"
            android:contentDescription="Selected"
            app:tint="@color/blue_600"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>