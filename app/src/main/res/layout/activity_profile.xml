<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_50">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_circle_decoration"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="-40dp"
            android:layout_marginTop="-40dp" />

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_queue_chip"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:contentDescription="Back" />
        </LinearLayout>

        <!-- Avatar circle (tappable to change photo) -->
        <FrameLayout
            android:id="@+id/avatar_circle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_below="@id/btn_back"
            android:layout_marginBottom="12dp">

            <!-- Initials background -->
            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_avatar_initials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JD"
                    android:textColor="@color/blue_600"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Profile photo (shown once uploaded) -->
            <ImageView
                android:id="@+id/iv_avatar_photo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Profile photo" />

            <!-- Camera badge -->
            <LinearLayout
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_camera_badge"
                android:gravity="center"
                android:layout_gravity="bottom|end">
                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/white"
                    android:contentDescription="Change photo" />
            </LinearLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Juan dela Cruz"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_below="@id/avatar_circle" />

        <TextView
            android:id="@+id/tv_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="juan@email.com"
            android:textColor="#BFFFFFFF"
            android:textSize="13sp"
            android:layout_below="@id/tv_profile_name"
            android:layout_marginTop="4dp" />

        <!-- Role badge -->
        <TextView
            android:id="@+id/tv_role_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESIDENT"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_admin_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_below="@id/tv_profile_email"
            android:layout_marginTop="8dp" />

        <!-- Edit profile button -->
        <LinearLayout
            android:id="@+id/btn_edit_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_queue_chip"
            android:gravity="center"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/white"
                android:contentDescription="Edit Profile" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Personal Info Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Information"
                android:textColor="@color/gray_800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                style="@style/Widget.BarangayGo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Full Name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="14dp">
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_announce_icon_info"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_profile"
                                app:tint="@color/blue_600"
                                android:contentDescription="Name" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full Name"
                                android:textColor="@color/gray_400"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_info_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Juan dela Cruz"
                                android:textColor="@color/gray_800"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gray_100"
                        android:layout_marginBottom="14dp" />

                    <!-- Email row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="14dp">
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_announce_icon_info"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_bell_blue"
                                app:tint="@color/blue_600"
                                android:contentDescription="Email" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email"
                                android:textColor="@color/gray_400"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_info_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="juan@email.com"
                                android:textColor="@color/gray_800"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gray_100"
                        android:layout_marginBottom="14dp" />

                    <!-- Contact row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_announce_icon_info"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_queue"
                                app:tint="@color/blue_600"
                                android:contentDescription="Contact" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact Number"
                                android:textColor="@color/gray_400"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_info_contact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not set"
                                android:textColor="@color/gray_800"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/btn_edit_contact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textColor="@color/blue_600"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Booking History Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Bookings"
                android:textColor="@color/gray_800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Bookings container -->
            <LinearLayout
                android:id="@+id/bookings_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty bookings state -->
            <LinearLayout
                android:id="@+id/layout_no_bookings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_announce_info"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No bookings yet"
                    android:textColor="@color/blue_800"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your booking history will appear here"
                    android:textColor="@color/blue_600"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Security Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security"
                android:textColor="@color/gray_800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                style="@style/Widget.BarangayGo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/btn_change_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="6dp">
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_announce_icon_info"
                            android:gravity="center"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_check"
                                app:tint="@color/blue_600"
                                android:contentDescription="Password" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Change Password"
                                android:textColor="@color/gray_800"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Send a reset link to your email"
                                android:textColor="@color/gray_400"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/gray_400"
                            android:textSize="20sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log Out"
                android:textColor="@color/status_danger"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                app:strokeColor="@color/status_danger"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation (Profile active) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:id="@+id/nav_home_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Home" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/gray_400" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_book"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:id="@+id/nav_book_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_book"
                    android:contentDescription="Book" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/gray_400" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_queue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:id="@+id/nav_queue_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_queue"
                    android:contentDescription="Queue" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Queue"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/gray_400" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:background="@drawable/bg_nav_active"
                android:layout_marginBottom="3dp">
                <ImageView
                    android:id="@+id/nav_profile_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="Profile" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>