<resources>
    <style name="Theme.BarangayGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/maroon_800</item>
        <item name="colorPrimaryVariant">@color/maroon_900</item>
        <item name="colorOnPrimary">@color/cream_100</item>
        <item name="colorSecondary">@color/cream_600</item>
        <item name="colorSecondaryVariant">@color/cream_400</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/cream_50</item>
        <item name="android:windowBackground">@color/cream_50</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/gray_800</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>
    <!--  Admin header theme: dark status bar to match dark header  -->
    <style name="Theme.BarangayGo.Admin" parent="Theme.BarangayGo">
        <item name="android:statusBarColor">@color/maroon_900</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.BarangayGo.Splash" parent="Theme.BarangayGo">
        <item name="android:statusBarColor">@color/maroon_900</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/maroon_900</item>
    </style>
    <!--  Button Styles  -->
    <style name="Widget.BarangayGo.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/maroon_800</item>
        <item name="android:textColor">@color/cream_100</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
    <style name="Widget.BarangayGo.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/maroon_200</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/maroon_800</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
    <!--  Card Style  -->
    <style name="Widget.BarangayGo.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/gray_200</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
    <!--  Input Style  -->
    <style name="Widget.BarangayGo.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/maroon_200</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="hintTextColor">@color/gray_400</item>
        <item name="android:textColorHint">@color/gray_400</item>
    </style>
    <!--  Tab Style  -->
    <style name="Widget.BarangayGo.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabSelectedTextColor">@color/cream_100</item>
        <item name="tabTextColor">@color/gray_600</item>
        <item name="tabIndicatorColor">@color/maroon_800</item>
        <item name="tabBackground">@color/gray_100</item>
        <item name="tabTextAppearance">@style/TextAppearance.BarangayGo.Tab</item>
    </style>
    <style name="TextAppearance.BarangayGo.Tab" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>