<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarangayGo">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BarangayGo.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminActivity"
            android:exported="false" />

        <activity
            android:name=".activities.QueueTicketActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ServiceDetailActivity"
            android:exported="false" />

        <activity
            android:name=".activities.BookQueueActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AnnouncementsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.MyQueuesActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminSlotsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminServicesActivity"
            android:exported="false" />

        <activity
            android:name=".activities.AdminProfileActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ChooseAccountTypeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.BarangayRegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.ResidentRegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- FCM: receives token refresh and incoming push messages -->
        <service
            android:name=".services.BarangayGoMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
